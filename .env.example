# FleetForge Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database
# ============================================
DATABASE_URL=mongodb://localhost:27017/fleetforge
REDIS_URL=redis://localhost:6379

# ============================================
# MQTT Broker
# ============================================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=fleetforge-gateway

# ============================================
# Security
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=7d
FIRMWARE_SIGNING_KEY_PATH=./secrets/firmware-signing.key
DEVICE_CA_CERT_PATH=./secrets/device-ca.crt

# ============================================
# OTA Configuration
# ============================================
OTA_STORAGE_BUCKET=fleetforge-ota-packages
OTA_CDN_URL=https://cdn.fleetforge.io
DELTA_UPDATE_ENABLED=true
CANARY_DEPLOYMENT_PERCENTAGE=5

# ============================================
# AI/ML Service
# ============================================
AI_MODEL_REGISTRY_URL=http://localhost:5000
ANOMALY_DETECTION_THRESHOLD=0.85

# ============================================
# Observability
# ============================================
LOG_LEVEL=info
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ============================================
# External Services
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_PROJECT_ID=

