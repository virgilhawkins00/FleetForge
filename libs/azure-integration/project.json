{
  "name": "azure-integration",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/azure-integration/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:integration"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/azure-integration",
        "main": "libs/azure-integration/src/index.ts",
        "tsConfig": "libs/azure-integration/tsconfig.lib.json",
        "assets": ["libs/azure-integration/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/azure-integration/jest.config.ts"
      }
    }
  }
}

