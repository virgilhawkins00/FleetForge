{
  "name": "@fleetforge/monorepo",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "FleetForge - Enterprise IoT Platform for Secure OTA and Fleet Management",
  "author": "FleetForge Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/FleetForge"
  },
  "keywords": [
    "iot",
    "fleet-management",
    "ota",
    "mqtt",
    "nestjs",
    "microservices",
    "digital-twin",
    "edge-ai"
  ],
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=4",
    "build": "nx run-many --target=build --all --parallel=4",
    "test": "nx run-many --target=test --all --parallel=4",
    "test:cov": "nx run-many --target=test --all --parallel=4 --coverage",
    "lint": "nx run-many --target=lint --all --parallel=4",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "affected:test": "nx affected --target=test",
    "affected:build": "nx affected --target=build",
    "publish:libs": "node tools/scripts/publish-libs.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^7.3.1",
    "@nestjs/testing": "^11.1.16",
    "@nx/eslint": "^22.5.4",
    "@nx/eslint-plugin": "^22.5.4",
    "@nx/jest": "^22.5.4",
    "@nx/js": "^22.5.4",
    "@nx/nest": "^22.5.4",
    "@nx/node": "^22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "^22.5.4",
    "@nx/workspace": "^22.5.4",
    "@swc-node/register": "~1.8.0",
    "@swc/core": "~1.3.107",
    "@swc/helpers": "~0.5.3",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "~8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^15.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nx": "^22.5.4",
    "prettier": "^3.2.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^6.0.1",
    "@google-cloud/logging": "^10.0.3",
    "@google-cloud/pubsub": "^4.2.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^5.18.3",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/microservices": "^11.1.16",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.16",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "aedes": "^1.0.1",
    "aedes-server-factory": "^0.2.1",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "ioredis": "^5.10.0",
    "mongoose": "^8.23.0",
    "mqtt": "^5.15.0",
    "multer": "^2.1.1",
    "nest-winston": "^1.10.2",
    "next": "14.2.35",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "tslib": "^2.6.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
