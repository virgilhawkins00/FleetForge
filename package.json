{
  "name": "@fleetforge/monorepo",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "FleetForge - Enterprise IoT Platform for Secure OTA and Fleet Management",
  "author": "FleetForge Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/FleetForge"
  },
  "keywords": [
    "iot",
    "fleet-management",
    "ota",
    "mqtt",
    "nestjs",
    "microservices",
    "digital-twin",
    "edge-ai"
  ],
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=4",
    "build": "nx run-many --target=build --all --parallel=4",
    "test": "nx run-many --target=test --all --parallel=4",
    "test:cov": "nx run-many --target=test --all --parallel=4 --coverage",
    "lint": "nx run-many --target=lint --all --parallel=4",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "affected:test": "nx affected --target=test",
    "affected:build": "nx affected --target=build",
    "publish:libs": "node tools/scripts/publish-libs.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@nx/eslint": "18.0.0",
    "@nx/jest": "18.0.0",
    "@nx/js": "18.0.0",
    "@nx/nest": "18.0.0",
    "@nx/node": "18.0.0",
    "@nx/webpack": "^22.5.4",
    "@nx/workspace": "18.0.0",
    "@swc-node/register": "~1.8.0",
    "@swc/core": "~1.3.107",
    "@swc/helpers": "~0.5.3",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "~8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nx": "18.0.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "mongoose": "^8.23.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
