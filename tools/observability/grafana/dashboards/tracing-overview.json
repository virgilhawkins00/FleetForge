{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Open Jaeger UI",
      "type": "link",
      "url": "http://localhost:16686"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "search": { "query": "service=fleetforge-api" } },
      "title": "Recent Traces",
      "type": "traces",
      "targets": [{
        "queryType": "search",
        "service": "fleetforge-api",
        "limit": 20
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "title": "Spans Created",
      "type": "timeseries",
      "targets": [{
        "expr": "sum(rate(otel_traces_spans_exported_total{job=\"fleetforge-api\"}[5m])) by (exporter)",
        "legendFormat": "{{exporter}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "title": "Trace Duration Distribution",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Traces",
      "type": "stat",
      "targets": [{
        "expr": "sum(otel_traces_sampler_sampled_total{job=\"fleetforge-api\"})"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Export Errors",
      "type": "stat",
      "targets": [{
        "expr": "sum(increase(otel_traces_exporter_send_failed_total{job=\"fleetforge-api\"}[1h]))"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["mean"] } },
      "title": "Avg Span Duration",
      "type": "stat",
      "targets": [{
        "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"fleetforge-api\"}[5m])) by (le)) * 1000"
      }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fleetforge", "tracing", "jaeger"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FleetForge Distributed Tracing",
  "uid": "fleetforge-tracing",
  "version": 1,
  "weekStart": ""
