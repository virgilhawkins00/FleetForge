        "expr": "sum(increase(http_requests_total{job=\"fleetforge-api\"}[24h]))"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }] }, "unit": "decmbytes" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "id": 5,
